# 복사해서 .env 로 저장하고 값 채우기 (.env 는 gitignore 됨)
DART_API_KEY=              # https://opendart.fss.or.kr 발급 (무료)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY= # `pnpm supabase start` 출력의 SERVICE_ROLE_KEY
EDGAR_USER_AGENT=          # "앱이름/버전 (연락 이메일)" — SEC 요구사항
FINNHUB_API_KEY=           # finnhub.io 무료 (US 실시간 시세 — 과거 candle은 US 무료 미지원)
TIINGO_API_KEY=            # tiingo.com 무료 (US 과거 일봉/OHLCV 히스토리)
KIS_APP_KEY=               # KIS Developers (KR 시세)
KIS_APP_SECRET=
KIS_ENV=real               # real(실전) | vts(모의투자)
